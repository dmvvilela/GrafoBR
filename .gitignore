# Node / Next
node_modules/
.next/
out/
dist/
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Env
.env
.env.local
!.env.example

# Generated data (one file per politician). Keep the folder + its README only.
data/*
!data/.gitkeep
!data/README.md
!data/_emenda-destinations.json

# web/public/data is COMMITTED as the deploy data snapshot (Vercel serves it directly).
# Refresh it by re-running the pipeline (../data) then web/scripts/sync-data.mjs.
# Root data/ above stays the local pipeline output (gitignored).

# Reference clones (br-acc etc.) — study material, never shipped. Keep the README.
reference/*
!reference/README.md

# Caches / OS
.duckdb/
*.duckdb
.cache/
.DS_Store

# AI review artifact (intermediate; applied summaries live in committed data)
ai/summaries.json
