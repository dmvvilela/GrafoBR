# Copy to .env. None of these are needed until the relevant source/phase.

# Portal da Transparência requires a free API key (cadastre-se no portal).
PORTAL_TRANSPARENCIA_API_KEY=

# Where emitted files go (default: ../data)
OUTPUT_DIR=../data

# Build-time AI (Phase 5): local Ollama endpoint serving Gemma 4 12B
OLLAMA_HOST=http://localhost:11434
GEMMA_MODEL=gemma4:12b
